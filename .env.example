# --------------------------------------------------------------------------
# Vallordocs environment configuration (PRD 6. fejezet – Environment Variables)
#
# Copy to `.env` for local development. NEVER commit real secrets.
# The application validates these at start-up and refuses to boot if a required
# value is missing or malformed (see src/config/env.ts).
# --------------------------------------------------------------------------

# Runtime
NODE_ENV=development
APP_URL=http://localhost:3000

# Localisation
DEFAULT_LANGUAGE=hu
DEFAULT_TIMEZONE=Europe/Budapest
LOG_LEVEL=info

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vallordocs

# Queue (Redis for BullMQ)
REDIS_URL=redis://localhost:6379

# Authentication (min. 32 characters)
JWT_SECRET=change-me-to-a-long-random-secret-value-min-32

# AI provider (gemini | openai | claude | vertexai)
AI_PROVIDER=gemini
GEMINI_API_KEY=

# Storage provider (fly | r2 | s3 | azure | gcs)
STORAGE_PROVIDER=fly
FLY_STORAGE_PATH=/data/storage

# Cloudflare R2 (only required when STORAGE_PROVIDER=r2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=

# SMTP (outgoing mail)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
